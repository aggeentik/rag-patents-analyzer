# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LLM Configuration
# Choose one of the following model configurations:

# Option 1: Ollama (Local models - recommended for development)
LLM_MODEL=ollama/llama2
# LLM_MODEL=ollama/mistral
# LLM_MODEL=ollama/llama3
OLLAMA_API_BASE=http://localhost:11434

# Option 2: AWS Bedrock (Claude, Titan, Llama models)
# LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
# LLM_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION_NAME=us-east-1

# Option 3: OpenAI (if needed)
# LLM_MODEL=gpt-4
# LLM_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=your_openai_key_here

# LLM Parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Hybrid Retriever Configuration
RETRIEVER_BM25_WEIGHT=1.0
RETRIEVER_SEMANTIC_WEIGHT=1.0
RETRIEVER_GRAPH_WEIGHT=0.5
RETRIEVER_RRF_K=60

# Answer Generation
MAX_CONTEXT_CHUNKS=5
INCLUDE_CHUNK_METADATA=true
