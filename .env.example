# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LLM Configuration
# Choose one of the following model configurations:

# Option 1: Ollama (Local models - recommended for development)
LLM_MODEL=ollama/llama3.1:8b
# LLM_MODEL=ollama/mistral
# LLM_MODEL=ollama/llama3
OLLAMA_API_BASE=http://localhost:11434

# Option 2: Azure AI (GPT-4.1, etc.)
# LLM_MODEL=azure_ai/gpt-4.1
# AZURE_AI_API_KEY=your_azure_ai_key_here
# AZURE_AI_API_BASE=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview

# Option 3: AWS Bedrock (Claude, Titan, Llama models)
# LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
# LLM_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION_NAME=us-east-1

# Option 4: OpenAI
# LLM_MODEL=gpt-4
# LLM_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=your_openai_key_here

# LLM Parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Hybrid Retriever Configuration
RETRIEVER_BM25_WEIGHT=1.0
RETRIEVER_SEMANTIC_WEIGHT=1.0
RETRIEVER_GRAPH_WEIGHT=1.2
RETRIEVER_RRF_K=60

# Graph Retriever Configuration
# Set to false to use exact/pattern entity matching instead of cosine-similarity lookup
GRAPH_SEMANTIC_ENTITY_SEARCH=false

# Reranker Configuration
# Set to true to enable cross-encoder reranking after RRF fusion
RERANKER_ENABLED=false
# HuggingFace model ID for the cross-encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Answer Generation
MAX_CONTEXT_CHUNKS=5
INCLUDE_CHUNK_METADATA=true
